<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.example.Mapper.EmployeeMapper">
    <!--新增员工信息-->
    <insert id="addEmployee" >
        INSERT INTO employee(name, phone, id_card, entry_time, dept_id, deptname, username, status, salary)
        VALUES(#{name}, #{phone}, #{idCard}, #{entryTime}, #{deptId}, #{deptName}, #{username}, #{status}, #{salary})
    </insert>

    <!--查询全部员工信息-->
    <select id="getAllEmployee" resultType="org.example.DemoUser.Employee">
        SELECT * FROM employee
    </select>

    <!--根据id查询员工信息-->
    <select id="getEmployeeById" resultType="org.example.DemoUser.Employee">
        SELECT * FROM employee WHERE id = #{id}
    </select>

    <!--根据绑定用户名查询员工信息-->
    <select id="getEmployeeByUsername" resultType="org.example.DemoUser.Employee">
        SELECT * FROM employee WHERE username = #{username}
    </select>

    <!--修改员工信息-->
    <update id="updateEmployee" >
        UPDATE employee
        SET 
        <if test="name != null">name= #{name},</if>
        <if test="phone != null">phone= #{phone},</if>
        <if test="idCard != null">id_card= #{idCard},</if>
        <if test="entryTime != null">entry_time= #{entryTime},</if>
        <if test="deptId != null">dept_id= #{deptId},</if>
        <if test="deptName != null">deptname= #{deptName},</if>
        <if test="username != null and username != ''">username = #{username},</if>
        <if test="status != null and status != ''">status = #{status},</if>
        <if test="salary != null">salary = #{salary}</if>
        WHERE id = #{id}
    </update>

    <!--删除员工信息-->
    <delete id="deleteEmployee" >
        DELETE FROM employee WHERE id = #{id}
    </delete>

    <!-- 修改员工状态 -->
    <update id="updateEmployeeStatus">
        UPDATE employee SET status = #{status} WHERE id = #{id}
    </update>
</mapper>